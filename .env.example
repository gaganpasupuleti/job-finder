# Supabase (optional - for database sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# LinkedIn (optional - for authenticated scraping)
# WARNING: Never commit real credentials to source control.
# Use a dedicated app password or OAuth token where possible.
LINKEDIN_USER=your-email@example.com
LINKEDIN_PASS=your-password

# RapidAPI LinkedIn mode (optional)
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=linkedin-data-api.p.rapidapi.com
# Example endpoint; set this to your exact playground endpoint URL
RAPIDAPI_LINKEDIN_ENDPOINT=https://linkedin-data-api.p.rapidapi.com/search-jobs
# GET or POST depending on endpoint docs
RAPIDAPI_LINKEDIN_METHOD=GET
